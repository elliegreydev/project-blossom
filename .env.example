# Copy to .env.local and fill in from your Supabase project (Settings -> API,
# and Settings -> Database for the connection string). Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Service role key: server-only, never expose to the client. Used for admin
# tasks. Not needed until we build admin/support tooling.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (session pooler) - used by scripts/migrate.mjs
# to run supabase/*.sql. Settings -> Database -> Connection string -> URI.
SUPABASE_DB_URL=

# Web push (real, closed-app reminders for signed-in/synced accounts only -
# see src/lib/reminders.ts and src/app/api/cron/send-reminders). Generate a
# pair with: node -e "console.log(require('web-push').generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Shared secret the reminder cron sends when it hits /api/cron/send-reminders.
CRON_SECRET=
